{
  "name": "@cooking-game/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace @cooking-game/shared && npm run build --workspace @cooking-game/recipe-schema",
    "dev": "tsx watch src/index.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate deploy --config prisma.config.ts",
    "build": "npm run prisma:generate && node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.44",
    "@colyseus/schema": "^4.0.28",
    "@colyseus/ws-transport": "^0.17.13",
    "@cooking-game/recipe-schema": "0.1.0",
    "@cooking-game/shared": "0.1.0",
    "@prisma/adapter-better-sqlite3": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "express": "^5.1.0",
    "livekit-server-sdk": "^2.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@colyseus/sdk": "^0.17.43",
    "@types/express": "^5.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
